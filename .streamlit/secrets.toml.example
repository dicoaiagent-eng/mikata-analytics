# Streamlit Community Cloud 用 Secrets テンプレート
# Streamlit Cloud の「App settings > Secrets」にこの内容を貼り付ける。
# （ローカルでは .env とファイルを使うのでこのファイルは不要。example はコミットOK、
#  実体 secrets.toml は .gitignore 済みでコミットしない）

CHANNEL_ID = "UCxxxxxxxxxxxxxxxxxxxxxx"
SHEET_NAME = "ミカタ_アナリティクス台帳"
# 閲覧パスワード（外部共有の保護）。空にすると認証なし。
DASH_PASSWORD = "お好きな合言葉"

# service_account.json の中身をそのまま貼る
[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "...@....iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"

# token.json の中身をそのまま貼る（refresh_token を含むので自動更新される）
[youtube_token]
token = "..."
refresh_token = "..."
token_uri = "https://oauth2.googleapis.com/token"
client_id = "..."
client_secret = "..."
scopes = ["https://www.googleapis.com/auth/yt-analytics.readonly", "https://www.googleapis.com/auth/youtube.readonly"]
universe_domain = "googleapis.com"
account = ""
